    {
      "id": "http-claude-schedule",
      "name": "\ud83e\udd16 Find Best Slot",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2260,
        100
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic-api",
          "name": "Anthropic API Key"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "x-api-key",
              "value": "={{ $credentials.httpHeaderAuth.value }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are JARVIC-007. The Commander wants to schedule: {{ $('\ud83d\udccb Parse Mission Brief').first().json.INTEL.special_notes || $('\ud83d\udccb Parse Mission Brief').first().json.originalText }}\\n\\nIntel extracted: {{ JSON.stringify($('\ud83d\udccb Parse Mission Brief').first().json.INTEL) }}\\n\\nExisting calendar events this week: {{ JSON.stringify($input.all().map(e => ({ summary: e.json.summary, start: e.json.start, end: e.json.end }))) }}\\n\\nProvide a JSON response with:\\n- event_title: string\\n- start_datetime: ISO8601\\n- end_datetime: ISO8601\\n- location: string or null\\n- attendees: array of email strings\\n- description: string\\n- jarvis_confirmation: A suave confirmation message for WhatsApp (use Aussie surf/Bond style)\\n\\nRaw JSON only, no markdown.\"\n    }\n  ]\n}",
        "options": {}
      }
    },
    {
      "id": "code-parse-schedule",
      "name": "Parse Event Details",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2480,
        100
      ],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst raw = response.content?.[0]?.text || '{}';\nlet parsed;\ntry {\n  parsed = JSON.parse(raw.replace(/```json\\n?|```/g, '').trim());\n} catch(e) {\n  parsed = { jarvis_confirmation: 'Apologies Commander, I need more details to schedule this properly.', event_title: null };\n}\nreturn [{ json: { ...parsed, from: $('\ud83d\udccb Parse Mission Brief').first().json.from, phoneNumberId: $('\ud83d\udccb Parse Mission Brief').first().json.phoneNumberId } }];"
      }
    },
    {
      "id": "gcal-create",
      "name": "\ud83d\udcc5 Deploy Calendar Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.1,
      "position": [
        2700,
        100
      ],
      "credentials": {
