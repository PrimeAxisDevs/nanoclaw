    {
      "id": "http-claude-draft",
      "name": "\u270d\ufe0f Draft Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2040,
        380
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic-api",
          "name": "Anthropic API Key"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "x-api-key",
              "value": "={{ $credentials.httpHeaderAuth.value }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are JARVIC-007. Draft a message on behalf of your Commander.\\n\\nRequest: {{ $('\ud83d\udccb Parse Mission Brief').first().json.originalText }}\\nIntel: {{ JSON.stringify($('\ud83d\udccb Parse Mission Brief').first().json.INTEL) }}\\n\\nWrite a natural, warm message from the Commander to {{ $('\ud83d\udccb Parse Mission Brief').first().json.INTEL.personnel[0] || 'the recipient' }}.\\n\\nRespond with JSON only:\\n{\\n  \\\"recipient_name\\\": \\\"\\\",\\n  \\\"draft\\\": \\\"the message text\\\",\\n  \\\"preview_message\\\": \\\"JARVIC preview intro (e.g. 'Here's what I'd send Sarah, Commander...')\\\",\\n  \\\"send_method\\\": \\\"whatsapp or email\\\"\\n}\"\n    }\n  ]\n}",
        "options": {}
      }
    },
    {
      "id": "code-parse-draft",
      "name": "Parse Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2260,
        380
      ],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst raw = response.content?.[0]?.text || '{}';\nlet parsed;\ntry {\n  parsed = JSON.parse(raw.replace(/```json\\n?|```/g, '').trim());\n} catch(e) {\n  parsed = { preview_message: 'Could not draft message.', draft: '' };\n}\nreturn [{ json: { ...parsed, from: $('\ud83d\udccb Parse Mission Brief').first().json.from, phoneNumberId: $('\ud83d\udccb Parse Mission Brief').first().json.phoneNumberId } }];"
      }
    },
    {
      "id": "http-wa-preview",
      "name": "\ud83d\udcf1 Preview to Commander",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
