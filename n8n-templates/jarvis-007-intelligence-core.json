        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.from }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"{{ $json.preview_message }}\\n\\n---\\n{{ $json.draft }}\\n---\\n\\nSend it? Reply *yes* to send or *edit* to revise. \ud83d\udd76\ufe0f\" }\n}",
        "options": {}
      }
    },
