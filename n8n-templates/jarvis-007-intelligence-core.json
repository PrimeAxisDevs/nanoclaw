        "calendarId": "primary",
        "start": "={{ $json.start_datetime }}",
        "end": "={{ $json.end_datetime }}",
        "additionalFields": {
          "summary": "={{ $json.event_title }}",
          "location": "={{ $json.location }}",
          "description": "={{ $json.description }}"
        }
      }
    },
    {
